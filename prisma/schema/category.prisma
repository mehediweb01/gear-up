model Category {
  id          String      @id @default(ulid())
  name        String
  slug        String?      @unique @db.VarChar(255)
  description String?     @db.Text
  gears       GearItems[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("categories")
}
